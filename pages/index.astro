import '../styles/global.css';

const stack = ['C#', 'Lua', 'Vue', 'TypeScript', 'PostgreSQL', 'Prisma'];

const projects = [
  { name: 'Project One', desc: 'A quick description of what it does.', link: '#' },
  { name: 'Project Two', desc: 'Built with Vue and Supabase.', link: '#' },
];

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Your Name</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  
  <body class="min-h-screen">
    <div class="max-w-2xl mx-auto px-6 py-20 md:py-32">
      
      <!-- Header -->
      <header class="mb-20">
        <h1 class="text-xl font-semibold text-zinc-100">Your Name</h1>
        <p class="text-zinc-500 mt-1">Software Engineer. I build things for the web and beyond.</p>
      </header>

      <!-- About -->
      <section class="mb-16">
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4">About</h2>
        <p class="text-zinc-400 leading-relaxed">
          I'm a developer who likes building clean, fast software. I work across the stack, 
          from game logic in <span class="text-zinc-200">C#</span> and <span class="text-zinc-200">Lua</span> 
          to web apps using <span class="text-zinc-200">Vue</span>, <span class="text-zinc-200">TypeScript</span>, 
          and <span class="text-zinc-200">Postgres</span>. 
        </p>
      </section>

      <!-- Stack -->
      <section class="mb-16">
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4">Stack</h2>
        <div class="flex flex-wrap gap-2">
          {stack.map((tech) => (
            <span class="px-2.5 py-1 text-xs font-medium rounded-md bg-zinc-900 text-zinc-400 border border-zinc-800">
              {tech}
            </span>
          ))}
        </div>
      </section>

      <!-- Projects -->
      <section class="mb-16">
        <h2 class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-4">Projects</h2>
        <div class="space-y-4">
          {projects.map((project) => (
            <a href={project.link} class="block group">
              <div class="flex items-baseline justify-between">
                <h3 class="text-zinc-200 font-medium group-hover:text-white">
                  {project.name}
                </h3>
                <span class="text-zinc-600 text-sm group-hover:text-zinc-400">↗</span>
              </div>
              <p class="text-sm text-zinc-500 mt-1">{project.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Links / Footer -->
      <footer class="pt-8 border-t border-zinc-900">
        <div class="flex items-center gap-6 text-sm text-zinc-500">
          <a href="https://github.com/yourusername" class="hover:text-zinc-200">GitHub</a>
          <a href="mailto:you@email.com" class="hover:text-zinc-200">Email</a>
          <span class="text-zinc-800">•</span>
          <span>© 2026</span>
        </div>
      </footer>

    </div>
  </body>
</html>
